    "@react-navigation/native": "^7.0.14",
    "@stripe/stripe-react-native": "0.50.3",
    "@supabase/supabase-js": "^2.58.0",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.34",
    "expo-av": "^16.0.8",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
